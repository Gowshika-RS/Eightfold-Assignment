# =========================
# Python Cache Files
# =========================
# Ignores compiled bytecode and cache directories generated by Python.
__pycache__/
*.pyc
*.pyo

# =========================
# Virtual Environments
# =========================
# Ignores local virtual environment directories used for isolated dependencies.
venv/
.venv/
env/

# =========================
# Pytest Cache
# =========================
# Ignores cache directories created by pytest during test runs.
.pytest_cache/

# =========================
# IDE / Editor Files
# =========================
# Ignores workspace settings and configurations for VS Code, IntelliJ, etc.
.vscode/
.idea/

# =========================
# OS Generated Files
# =========================
# Ignores system-specific files created by macOS and Windows.
.DS_Store
Thumbs.db

# =========================
# Log Files
# =========================
# Ignores runtime log files to prevent them from cluttering the repository.
*.log

# =========================
# Build Artifacts
# =========================
# Ignores build output, distribution folders, and egg-info directories.
build/
dist/
*.egg-info/

# =========================
# Temporary Files
# =========================
# Ignores temporary swap files and backups created by text editors or OS.
*.swp
*~
*.bak
*.tmp

# =========================
# Deliverables
# =========================
# Note: Source code, configuration, tests, input files, and documentation 
# are deliberately NOT ignored so they are tracked by version control.
# Specifically, `output/result.json` is kept tracked as it is part of the 
# assignment deliverables.
